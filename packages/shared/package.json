{
  "name": "@wx/shared",
  "version": "0.57.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./lib/*.js": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    },
    "./db/tables/*.js": {
      "types": "./dist/db/tables/*.d.ts",
      "default": "./dist/db/tables/*.js"
    },
    "./db/relations/*.js": {
      "types": "./dist/db/relations/*.d.ts",
      "default": "./dist/db/relations/*.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "drizzle-orm": "^0.44.6",
    "fast-xml-parser": "^5.3.0",
    "mysql2": "^3.15.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
