{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "nodenext",
    "target": "es2022",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "outDir": "../dist/shared",
    "rootDir": "."
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "dist"]
}
