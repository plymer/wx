{
  "name": "prairie-wx",
  "version": "0.57.0",
  "description": "a weather application based on open source software and data",
  "license": "MIT",
  "author": "Ryan Pimiskern",
  "type": "module",
  "workspaces": [
    "app/client",
    "app/server"
  ],
  "scripts": {
    "build": "run-s build:client build:server",
    "build:client": "npm run build -w app/client",
    "build:server": "npm run build -w app/server",
    "dev:client": "npm run dev -w app/client",
    "dev:server": "npm run dev -w app/server",
    "dev": "run-p dev:*",
    "lint": "eslint .",
    "preview:client": "npm run preview -w app/client",
    "preview:server": "pm2 restart beta.config.cjs",
    "preview": "run-p preview:*",
    "deploy": "pm2 stop beta.config.cjs && npm install --include=dev && npm run build && pm2 start beta.config.cjs && pm2 save",
    "sprites:icons": "spreet --sdf public/sprites/icons public/sprites/icons && spreet --retina --sdf public/sprites/icons public/sprites/icons@2x",
    "db:push": "npm run aqdb:push && npm run avwxdb:push",
    "aqdb:push": "drizzle-kit push --config aq.drizzle.config.ts",
    "avwxdb:push": "drizzle-kit push --config avwx.drizzle.config.ts"
  },
  "dependencies": {
    "@turf/turf": "^7.2.0",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.5",
    "fast-xml-parser": "^5.2.5",
    "mysql2": "^3.15.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "eslint": "^9.36.0",
    "npm-run-all2": "^8.0.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0"
  }
}
