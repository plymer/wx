{
  "name": "prairie-wx",
  "version": "1.0.0",
  "description": "a weather application based on open source software and data",
  "license": "MIT",
  "author": "Ryan Pimiskern / Rose Carlsen",
  "type": "module",
  "scripts": {
    "check": "pnpm run check:client && pnpm run check:server",
    "check:client": "pnpm --filter client run check",
    "check:server": "pnpm --filter server run check",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "pnpm --filter client build",
    "build:server": "pnpm --filter server build",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev": "pnpm build:server && pm2 start data-dev.config.cjs && concurrently 'pnpm --filter client dev' 'pnpm --filter server dev'",
    "preview:client": "pnpm --filter client preview",
    "preview:server": "pnpm --filter server start",
    "preview": "pnpm run build:server && pm2 restart data.config.cjs && concurrently 'pnpm run preview:client' 'pnpm run preview:server'",
    "deploy:prod": "pnpm install && pm2 stop data.config.cjs && pnpm build && pm2 start data.config.cjs && pm2 restart prod.config.cjs && pm2 save",
    "deploy:dev": "pnpm install && pm2 stop data-dev.config.cjs && pnpm build && pm2 start data-dev.config.cjs && pm2 restart dev.config.cjs && pm2 save",
    "sprites:icons": "spreet --sdf public/sprites/icons public/sprites/icons && spreet --retina --sdf public/sprites/icons public/sprites/icons@2x",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@plymer/fast-barnes-ts": "^0.3.2",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "@turf/turf": "^7.3.4",
    "better-sqlite3": "^12.4.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "fast-xml-parser": "^5.5.9",
    "lru-cache": "^11.2.7",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.21.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "react-router": "^7.13.2",
    "sonner": "^2.0.7",
    "suncalc": "^1.9.0",
    "superjson": "^2.2.6",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/suncalc": "^1.9.2",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "0.25.12",
      "@rollup/plugin-terser>serialize-javascript": "7.0.5"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
