{
  "name": "prairie-wx",
  "version": "0.57.0",
  "description": "a weather application based on open source software and data",
  "license": "MIT",
  "author": "Ryan Pimiskern",
  "type": "module",
  "workspaces": [
    "client",
    "data",
    "server",
    "shared"
  ],
  "scripts": {
    "build": "run-s build:client build:server build:data",
    "build:client": "npm run build -w client",
    "build:server": "npm run build -w server",
    "build:data": "npm run build -w data",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "dev": "run-p dev:*",
    "lint": "eslint .",
    "preview:client": "npm run preview -w client",
    "preview:server": "pm2 restart beta.config.cjs",
    "preview": "run-p preview:*"
  },
  "dependencies": {
    "@turf/turf": "^7.2.0",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.5",
    "fast-xml-parser": "^5.2.5",
    "mysql2": "^3.15.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "eslint": "^9.36.0",
    "npm-run-all2": "^8.0.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0"
  }
}
