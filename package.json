{
  "name": "prairie-wx",
  "version": "0.57.0",
  "description": "a weather application based on open source software and data",
  "license": "MIT",
  "author": "Ryan Pimiskern",
  "type": "module",
  "scripts": {
    "check": "pnpm run check:client && pnpm run check:server",
    "check:client": "pnpm --filter client run check",
    "check:server": "pnpm --filter server run check",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "pnpm --filter client build",
    "build:server": "pnpm --filter server build",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev": "concurrently 'pnpm --filter client dev' 'pnpm --filter server dev'",
    "lint": "eslint .",
    "preview:client": "pnpm --filter client preview",
    "preview:server": "pm2 restart beta.config.cjs",
    "preview": "concurrently 'pnpm run preview:client' 'pnpm run preview:server'",
    "deploy": "pm2 stop beta.config.cjs && pnpm install --include=dev && pnpm run build && pm2 start beta.config.cjs && pm2 save",
    "sprites:icons": "spreet --sdf public/sprites/icons public/sprites/icons && spreet --retina --sdf public/sprites/icons public/sprites/icons@2x",
    "db:push": "pnpm run aqdb:push && pnpm run avwxdb:push",
    "aqdb:push": "drizzle-kit push --config aq.drizzle.config.ts",
    "avwxdb:push": "drizzle-kit push --config avwx.drizzle.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.89.0",
    "@tanstack/react-query-devtools": "^5.89.0",
    "@trpc/client": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "@trpc/tanstack-react-query": "^11.6.0",
    "@turf/turf": "^7.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.6",
    "drizzle-orm": "^0.44.5",
    "fast-xml-parser": "^5.2.5",
    "lucide-react": "^0.540.0",
    "maplibre-gl": "^5.7.3",
    "mysql2": "^3.15.2",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-map-gl": "^8.0.4",
    "react-router": "^7.9.1",
    "sonner": "^2.0.7",
    "suncalc": "^1.9.0",
    "vaul": "^1.1.2",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/eslint-plugin-query": "^5.89.0",
    "@types/cors": "^2.8.19",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/suncalc": "^1.9.2",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.12",
    "vite-plugin-pwa": "^1.0.1"
  }
}
